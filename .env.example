# CantonTrace Environment Configuration

# API Gateway
PORT=3001
NODE_ENV=development
JWT_SECRET=change-this-in-production

# Database
DATABASE_URL=postgresql://cantontrace:cantontrace@localhost:5432/cantontrace
POSTGRES_USER=cantontrace
POSTGRES_PASSWORD=cantontrace
POSTGRES_DB=cantontrace

# Redis
REDIS_URL=redis://localhost:6379

# Engine Service
ENGINE_SERVICE_URL=http://localhost:3002

# Canton Connection (for development)
CANTON_LEDGER_API_ENDPOINT=
CANTON_IAM_URL=

# Frontend
VITE_API_URL=/api/v1

# Logging
LOG_LEVEL=info
